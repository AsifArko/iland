{
  "name": "iland",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Asif Imtiyaz Chowdhury <asif.imch@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:platform-neutral": "./scripts/build-platform-neutral.sh",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL) require('child_process').execSync('npx husky install')\"",
    "pre-commit": "lint-staged",
    "update-orders": "node scripts/update-orders.js",
    "typegen": "sanity schema extract && sanity typegen generate",
    "sanity:deploy": "sanity deploy",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:ci": "jest --ci --coverage --watchAll=false --maxWorkers=2 --detectOpenHandles --forceExit",
    "test:ci:robust": "jest --ci --coverage --watchAll=false --maxWorkers=1 --detectOpenHandles --forceExit --testTimeout=30000",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "analyze": "ANALYZE=true next build",
    "security:audit": "npm audit --audit-level=critical",
    "security:fix": "npm audit fix",
    "security:scan": "npm run security:audit || echo 'Security audit completed with warnings' && npm run security:fix",
    "health:check": "curl -f http://localhost:3000/api/health",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "bundle:analyze": "npm run build && npm run analyze",
    "performance:test": "npm run build && npm run start & sleep 10 && npm run lighthouse && pkill -f 'next start'",
    "test:monitoring": "node scripts/test-monitoring.js",
    "performance:monitor": "node scripts/performance-monitor.js",
    "security:test": "node scripts/security-test.js",
    "update-animations": "node scripts/update-animations.js",
    "bundle:size": "npm run build && npx next-bundle-analyzer",
    "optimize:images": "node scripts/optimize-images.js",
    "ci:full": "npm run lint && npm run type-check && npm run test:ci && npm run build && npm run security:scan",
    "deploy:check": "npm run ci:full && npm run performance:test",
    "vercel:setup": "bash scripts/vercel-env-setup.sh"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@sanity/client": "^7.8.1",
    "@sanity/image-url": "^1.1.0",
    "@sanity/vision": "^3.99.0",
    "@stripe/stripe-js": "^7.6.1",
    "@types/nodemailer": "^6.4.17",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "dotenv": "^17.2.1",
    "lucide-react": "^0.525.0",
    "next": "15.4.6",
    "next-sanity": "^9.12.3",
    "nodemailer": "^7.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-is": "19.1.1",
    "sanity": "^3.99.0",
    "stripe": "^18.3.0",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.4.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^51.4.1",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "image-webpack-loader": "^8.1.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "lighthouse": "^11.6.0",
    "lint-staged": "^16.1.2",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
